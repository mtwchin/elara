# ── Required ────────────────────────────────────────────────────────────────
# Backend API URL — set this to your Railway/Render backend URL in production
# In local dev, omit this file entirely (defaults to http://localhost:8000)
VITE_API_URL=https://your-backend.railway.app

# ── Optional ─────────────────────────────────────────────────────────────────
# Clerk — if you wire up Clerk auth (currently using local JWT)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
