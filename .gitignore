# Secrets — never commit real env files
backend/.env
frontend/.env
frontend/.env.local

# Node.js
node_modules/
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Python
backend/venv/
backend/__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# Databases
backend/portfolio.db

# Uploaded documents (user files — not committed)
backend/uploads/*
!backend/uploads/.gitkeep

# OS
.DS_Store
Thumbs.db

# IDEs/Editors
.vscode/
.idea/
*.swp
*.swo

# Project Specific
.agents/
.claude/
