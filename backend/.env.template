# ── Required ────────────────────────────────────────────────────────────────
# Secret used to sign local JWT tokens (register/login). Pick any long random string.
RE_PORTFOLIO_JWT_SECRET=change_me_to_a_long_random_secret

# Google Gemini — AI features: renewal letters, portfolio advice, document extraction
GOOGLE_API_KEY=your_google_api_key

# Runtime environment and public app URL used for redirects.
# When APP_ENV=production, DATABASE_URL, CORS_ORIGINS, PUBLIC_APP_URL, and
# RE_PORTFOLIO_JWT_SECRET are validated at startup and cannot use local defaults.
APP_ENV=development
PUBLIC_APP_URL=http://localhost:5173

# Database / worker infrastructure.
# Local dev can omit DATABASE_URL to use SQLite. Production should use PostgreSQL.
DATABASE_URL=
REDIS_URL=redis://localhost:6379/0
UPLOAD_DIR=./uploads

# ── Optional ─────────────────────────────────────────────────────────────────
# CORS allowlist — comma-separated origins permitted to call the API.
# Defaults to local dev origins if unset. Set to your frontend URL(s) in prod.
CORS_ORIGINS=http://localhost:5173,http://localhost,http://127.0.0.1:5173

# Per-request debug logging — set to true to log every request/response.
# Leave unset (default) in production.
DEBUG_REQUEST_LOGS=false

# In-memory per-process rate limiting. Use Redis/API-gateway limits for multi-instance production.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_AI_MAX=60
RATE_LIMIT_UPLOAD_MAX=60
RATE_LIMIT_MARKET_MAX=180
RATE_LIMIT_DEFAULT_MAX=600

# New account password policy.
MIN_PASSWORD_LENGTH=10

# RapidAPI (Zillow Data) — market rent on dashboard + renewal letters
# App works without this; falls back to +3% heuristic
RAPIDAPI_KEY=
ZILLOW_API_BASE_URL=https://zillow-com1.p.rapidapi.com
RAPIDAPI_HOST=zillow-com1.p.rapidapi.com
MARKET_DATA_TIMEOUT_SECONDS=5.0

# Clerk — if you wire up Clerk auth (currently using local JWT)
CLERK_SECRET_KEY=
CLERK_JWKS_URL=
CLERK_AUDIENCE=
CLERK_ISSUER=

# Stripe billing. Set price IDs for each plan before enabling checkout.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PORTFOLIO=
STRIPE_PRICE_ID_OPERATOR=

# Transactional email via Resend (https://resend.com).
# If absent, emails are logged to stdout only (dev mode).
RESEND_API_KEY=re_...
EMAIL_FROM=Elara <noreply@getelara.com>

# Observability.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
